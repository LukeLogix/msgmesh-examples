# MsgMesh chat-web 設定 —— 複製成 .env 後填入你的值。
# .env 已被 .gitignore 排除,別 commit。改完要重新 build / 重啟 server 才會生效。
#
# 這個樣板預設走 token-broker:前端零長期 key。key 只放在下方「後端」區,
# 由 server.js 用它向平台換短期降權 token 給前端。兩區的 TOPIC 必須一致。

# ── 後端(server.js 用;絕不進前端 bundle)─────────────────────────────
# API key —— 需能對下方 topic 同時 publish 與 subscribe(用來鑄短期 token)。
# 只存在這支後端,永不進瀏覽器。
MSGMESH_API_KEY=replace-me
# 治理面位址:鑄 token 的 POST /v1/tokens 打這裡(本機平台預設 :8080)。
MSGMESH_CONTROL_PLANE_URL=http://localhost:8080
# 聊天室 topic(收發同一個;需與前端 VITE_MSGMESH_TOPIC 一致)。
MSGMESH_TOPIC=chat.lobby
# token-broker 監聽埠(server.js 同時服務 /api/token 與 dist/ 靜態前端)。
PORT=8787

# ── 前端(VITE_ 前綴會被打包進 bundle;皆為非敏感值,無長期 key)──────────
# 收發服務位址(本機平台預設如下;線上填你的實例位址)。
VITE_MSGMESH_GATEWAY_URL=http://localhost:8081
# 即時服務位址(SSE 串流打這裡)。
VITE_MSGMESH_REALTIME_URL=http://localhost:8082
# 聊天室 topic(需與後端 MSGMESH_TOPIC 一致)。
VITE_MSGMESH_TOPIC=chat.lobby
