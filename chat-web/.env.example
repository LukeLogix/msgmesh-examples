# MsgMesh 連線設定 —— 複製成 .env 後填入你的值。
# .env 已被 .gitignore 排除,別 commit。改完要重啟 dev server 才會生效。
#
# 注意:Vite 只會把「VITE_ 前綴」的變數注入前端 bundle。

# 收發服務位址(本機平台預設如下;線上填你的實例位址)
VITE_MSGMESH_GATEWAY_URL=http://localhost:8081
VITE_MSGMESH_REALTIME_URL=http://localhost:8082

# API key —— 會被打包進前端 bundle,僅適合本機 / 內部 demo。
# 需能對下方 topic 同時 publish 與 subscribe(例如一把含這兩種能力的 key)。
# 上線請改用 token-broker(見 README「上線安全」),別把長期 key 放進瀏覽器。
VITE_MSGMESH_API_KEY=replace-me

# 聊天室 topic(收發同一個)
VITE_MSGMESH_TOPIC=chat.lobby
