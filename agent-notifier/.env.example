# MsgMesh 連線設定 —— 複製成 .env 後填入。.env 已被 .gitignore 排除,別 commit。
# npm start 用 Node 的 --env-file 讀這個檔(需 Node ≥ 20.6;Node 18 的替代跑法見 README)。

# 收訊走 gateway;填你的實例位址,本機平台預設如下。
MSGMESH_GATEWAY_URL=http://localhost:8081

# API key —— 收訊需 consumer(或含 subscribe 能力)的 key。只留在 .env,別 commit。
MSGMESH_API_KEY=replace-me

# 要監看的 topic 與消費者 group(同一個 group 起多個實例會分攤訊息)。
MSGMESH_TOPIC=orders
MSGMESH_GROUP=agent-notifier
